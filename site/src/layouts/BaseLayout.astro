---
import '../styles/global.css';
import { site } from '../data/site';
import { languages } from '../i18n/ui';
import { getLocale, useTranslations, switchLangUrl } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);

const {
  title = site.title,
  description = t('meta.description'),
  ogImage = '/images/og-image.png',
  ogType = 'website',
} = Astro.props;

const pageTitle = title;
const canonicalUrl = new URL(Astro.url.pathname, site.url);
---

<!doctype html>
<html lang={lang} class="text-gray-700">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content={site.author} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preload" href="/fonts/Roboto-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Roboto-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="canonical" href={canonicalUrl} />

    {Object.keys(languages).map((l) => (
      <link rel="alternate" hreflang={l} href={new URL(switchLangUrl(Astro.url, l as keyof typeof languages), site.url)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(Astro.url.pathname, site.url)} />

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, site.url)} />

    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@mlorentedev" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, site.url)} />

    <title>{pageTitle}</title>
  </head>
  <body class="flex flex-col min-h-screen">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:bg-cyan-700 focus:text-white focus:px-4 focus:py-2 focus:rounded">
      Skip to content
    </a>
    <slot />
  </body>
</html>
