---
import { site } from '../data/site';

interface Props {
  formId: string;
  tag: string;
  utmSource?: string;
  placeholder?: string;
  buttonText: string;
  successText?: string;
  errorText?: string;
}

const {
  formId,
  tag,
  utmSource = 'landing_page',
  placeholder = 'tu@email.com',
  buttonText,
  successText = '¡Listo! Revisa tu email.',
  errorText = 'Por favor, introduce un email válido.',
} = Astro.props;
---

<div class="not-prose bg-cyan-700 text-white p-4 rounded-md max-w-xs mx-auto">
  <form
    id={formId}
    class="flex flex-col gap-4"
    data-api-url={`${site.api.baseUrl}/api/subscribe`}
    data-tag={tag}
    data-utm-source={utmSource}
    data-success-text={successText}
    data-error-text={errorText}
    novalidate
  >
    <input
      type="email"
      name="email"
      required
      autocomplete="email"
      placeholder={placeholder}
      class="w-full p-2 text-cyan-700 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-cyan-300"
      aria-label="Email"
    />
    <button
      type="submit"
      class="w-full px-4 py-2.5 bg-white text-cyan-700 border border-transparent rounded-md text-sm font-medium hover:bg-cyan-700 hover:text-white hover:border-white transition-colors focus:outline-none focus:ring-2 focus:ring-white"
    >
      {buttonText}
    </button>
    <div class="flex justify-center items-center text-center">
      <input type="checkbox" id={`privacy-${formId}`} name="privacy_policy" class="mr-2" required />
      <label for={`privacy-${formId}`} class="text-xs text-white">
        Acepto la <a href="/es/legal/privacy" target="_blank" class="text-white underline">política de privacidad</a>
      </label>
    </div>
    <p class="subscribe-msg text-xs text-center hidden"></p>
  </form>
</div>

<script>
  document.querySelectorAll('form[data-api-url]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const msg = f.querySelector('.subscribe-msg') as HTMLElement;
      const button = f.querySelector('button[type="submit"]') as HTMLButtonElement;
      const email = new FormData(f).get('email') as string;

      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        if (msg) {
          msg.textContent = f.dataset.errorText || 'Invalid email';
          msg.className = 'subscribe-msg text-xs text-center text-red-200';
        }
        return;
      }

      button.disabled = true;
      button.textContent = '...';

      try {
        const res = await fetch(f.dataset.apiUrl!, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            tags: [f.dataset.tag],
            utm_source: f.dataset.utmSource,
          }),
        });

        if (res.status === 201 || res.status === 409) {
          if (msg) {
            msg.textContent = f.dataset.successText || 'Done!';
            msg.className = 'subscribe-msg text-xs text-center text-cyan-200';
          }
          button.textContent = 'Recibido';
        } else {
          throw new Error(`Status ${res.status}`);
        }
      } catch {
        if (msg) {
          msg.textContent = 'Error. Inténtalo de nuevo.';
          msg.className = 'subscribe-msg text-xs text-center text-red-200';
        }
        button.disabled = false;
        button.textContent = f.querySelector('button')?.textContent || 'Retry';
      }
    });
  });
</script>
