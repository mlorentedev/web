---
import { experience, localizeExperience } from '../data/experience';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  /** Current UI language — selects role/location copy and the "Present" label. */
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const entries = experience.map((e) => localizeExperience(e, lang, t('experience.present')));
---

<section data-experience class="py-14 border-t border-gray-100">
  <div class="max-w-4xl mx-auto px-4">
    <h2 class="text-sm font-medium text-gray-500 tracking-widest uppercase mb-8">
      <span class="text-cyan-700">[ 01 /</span> {t('home.experience')} <span class="text-cyan-700">]</span>
    </h2>
    <ol class="space-y-6">
      {entries.map((e) => (
        <li data-role class="flex flex-col sm:flex-row sm:gap-6">
          <span class="text-sm text-gray-500 tabular-nums shrink-0 sm:w-28 mb-1 sm:mb-0">{e.period}</span>
          <div class="sm:border-l sm:border-gray-100 sm:pl-6 flex-grow">
            <h3 class="text-base leading-snug">
              <span class="font-bold text-gray-800">{e.role}</span>
              <span class="text-gray-500"> · {e.company} · {e.location}</span>
            </h3>
            <p class="text-sm text-gray-600 mt-1 leading-relaxed">{e.highlight}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
