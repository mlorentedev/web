---
// GDPR cookie-consent banner. Shown only until the user decides; the choice persists
// in localStorage. Accept → load GA4 (window.loadGA from Analytics.astro). Reject →
// nothing. Cloudflare Web Analytics is cookieless and is not affected by this choice.
import { getLocale, useTranslations } from '../i18n/utils';

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
const privacyUrl = '/es/legal/privacy';
---

<div
  id="cookie-banner"
  class="fixed bottom-0 inset-x-0 z-50 bg-cyan-900 text-white text-sm px-4 py-3 shadow-lg"
  hidden
>
  <div class="max-w-3xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
    <p class="text-center sm:text-left">
      {t('cookie.text')}
      <a href={privacyUrl} class="underline hover:text-cyan-200">{t('cookie.policy')}</a>
    </p>
    <div class="flex gap-2 shrink-0">
      <button
        id="cookie-reject"
        class="px-3 py-1.5 rounded border border-white/40 hover:bg-white/10 transition-colors"
      >
        {t('cookie.reject')}
      </button>
      <button
        id="cookie-accept"
        class="px-3 py-1.5 rounded bg-white text-cyan-900 font-medium hover:bg-cyan-100 transition-colors"
      >
        {t('cookie.accept')}
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var banner = document.getElementById('cookie-banner');
    if (!banner) return;
    if (!localStorage.getItem('cookie-consent')) {
      banner.hidden = false; // only show when the user hasn't decided yet
    }
    var accept = document.getElementById('cookie-accept');
    var reject = document.getElementById('cookie-reject');
    if (accept) {
      accept.addEventListener('click', function () {
        localStorage.setItem('cookie-consent', 'granted');
        banner.hidden = true;
        if (window.loadGA) window.loadGA();
      });
    }
    if (reject) {
      reject.addEventListener('click', function () {
        localStorage.setItem('cookie-consent', 'denied');
        banner.hidden = true;
      });
    }
  })();
</script>
