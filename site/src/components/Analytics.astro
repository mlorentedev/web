---
// Google Analytics 4 — GATED behind cookie consent (GDPR, WEB-024). gtag loads only
// after the user accepts (see CookieBanner.astro, which calls window.loadGA). Renders
// nothing when no measurement ID is set. Cloudflare Web Analytics is cookieless and
// runs at the edge, so it is NOT gated here — see `site.analytics` in src/data/site.ts.
import { site } from '../data/site';

const gaId = site.analytics.googleAnalyticsId;
---

{
  gaId && (
    <script is:inline define:vars={{ gaId }}>
      window.loadGA = function () {
        if (window.__gaLoaded) return;
        window.__gaLoaded = true;
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag() { window.dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', gaId);
      };
      // Returning visitors who already consented: load immediately.
      if (localStorage.getItem('cookie-consent') === 'granted') {
        window.loadGA();
      }
    </script>
  )
}
