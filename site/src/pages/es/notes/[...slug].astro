---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { getLocale, useTranslations, useTranslatedPath, getDateLocale } from '../../../i18n/utils';

export async function getStaticPaths() {
  const notes = (await getCollection('notes', ({ data }: CollectionEntry<'notes'>) => !data.draft && data.lang === 'es'))
    .sort((a: CollectionEntry<'notes'>, b: CollectionEntry<'notes'>) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

  return notes.map((note: CollectionEntry<'notes'>, i: number) => ({
    params: { slug: note.id },
    props: {
      note,
      prev: i > 0 ? { id: notes[i - 1].id, title: notes[i - 1].data.title } : null,
      next: i < notes.length - 1 ? { id: notes[i + 1].id, title: notes[i + 1].data.title } : null,
    },
  }));
}

const { note, prev, next } = Astro.props as {
  note: CollectionEntry<'notes'>;
  prev: { id: string; title: string } | null;
  next: { id: string; title: string } | null;
};
const { Content } = await render(note);

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const formattedDate = note.data.pubDate.toLocaleDateString(getDateLocale(lang), {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={note.data.title} description={note.data.description} ogType="article">
  <Header />
  <main id="main-content" class="flex-grow pt-12">
    <section class="pt-16 pb-16 md:pt-20 md:pb-20">
      <div class="max-w-3xl mx-auto px-4">
        <article>
          <header class="mb-10">
            <time class="text-sm text-gray-500">{formattedDate}</time>
            <h1 class="text-3xl font-extrabold text-gray-800 mt-3">{note.data.title}</h1>
            <div class="flex flex-wrap gap-2 mt-4">
              {note.data.tags.map((tag: string) => (
                <a href={translatePath(`/tags/${tag.toLowerCase()}`)} class="px-2 py-0.5 text-xs rounded bg-gray-100 text-gray-500 border border-gray-200 hover:bg-cyan-700 hover:text-white hover:border-cyan-700 transition-colors">
                  {tag}
                </a>
              ))}
            </div>
          </header>
          <div class="prose prose-lg max-w-none prose-headings:font-extrabold prose-headings:text-gray-800 prose-p:text-gray-600 prose-li:text-gray-600 prose-strong:text-gray-800">
            <Content />
          </div>
        </article>
      </div>
    </section>

    <nav class="py-12 md:py-16 border-t border-gray-200">
      <div class="max-w-3xl mx-auto px-4">
        <div class="flex items-center justify-between gap-4">
          {prev ? (
            <a href={translatePath(`/notes/${prev.id}`)} class="group flex-1 min-w-0">
              <span class="text-xs text-gray-400">&larr; {t('note.prev')}</span>
              <span class="block text-sm font-bold text-gray-700 group-hover:text-cyan-700 transition-colors truncate mt-0.5">{prev.title}</span>
            </a>
          ) : <div class="flex-1" />}
          <a href={translatePath('/notes')} class="text-xs text-gray-400 hover:text-cyan-700 transition-colors shrink-0 px-2">{t('notes.all')}</a>
          {next ? (
            <a href={translatePath(`/notes/${next.id}`)} class="group flex-1 min-w-0 text-right">
              <span class="text-xs text-gray-400">{t('note.next')} &rarr;</span>
              <span class="block text-sm font-bold text-gray-700 group-hover:text-cyan-700 transition-colors truncate mt-0.5">{next.title}</span>
            </a>
          ) : <div class="flex-1" />}
        </div>
      </div>
    </nav>
  </main>
  <Footer />
</BaseLayout>
