---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import { useTranslations, useTranslatedPath, getLocale } from '../i18n/utils';
import { projects, localize } from '../data/portfolio';
import ProjectCard from '../components/ProjectCard.astro';
import CredibilityBand from '../components/CredibilityBand.astro';
import Timeline from '../components/Timeline.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const notes: CollectionEntry<'notes'>[] = (await getCollection('notes', ({ data }: CollectionEntry<'notes'>) => !data.draft && data.lang === 'en'))
  .sort((a: CollectionEntry<'notes'>, b: CollectionEntry<'notes'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const stack = [
  { label: 'On-Premises', items: 'Linux · Proxmox · Bare metal' },
  { label: 'Orchestration', items: 'Kubernetes · Docker · Helm' },
  { label: 'IaC', items: 'Terraform · Ansible' },
  { label: 'Languages', items: 'Python · Go' },
  { label: 'Observability', items: 'Prometheus · Grafana · Loki' },
  { label: 'CI/CD', items: 'GitHub Actions · ArgoCD' },
  { label: 'Cloud', items: 'AWS' },
];
---

<BaseLayout>
  <Header />
  <main id="main-content" class="flex-grow pt-16">
    <Hero />

    <CredibilityBand lang={lang} />

    <Timeline lang={lang} />

    <section class="py-14 border-t border-gray-100">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-sm font-medium text-gray-500 tracking-widest uppercase mb-8">
          <span class="text-cyan-700">[ 02 /</span> {t('home.projects')} <span class="text-cyan-700">]</span>
        </h2>
        <a href="https://github.com/mlorentedev" target="_blank" rel="noopener noreferrer">
          <img
            src="https://ghchart.rshah.org/0e7490/mlorentedev"
            alt={t('meta.ghchart.alt')}
            width="722"
            height="112"
            class="w-full mb-8 hover:opacity-80 transition-opacity"
            loading="lazy"
          />
        </a>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {projects.map((project) => (
            <ProjectCard project={localize(project, lang)} lang={lang} />
          ))}
        </div>
      </div>
    </section>

    <section class="py-14 border-t border-gray-100">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-sm font-medium text-gray-500 tracking-widest uppercase mb-6">
          <span class="text-cyan-700">[ 03 /</span> {t('home.stack')} <span class="text-cyan-700">]</span>
        </h2>
        <div class="space-y-2">
          {stack.map(({ label, items }) => (
            <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-3">
              <span class="text-sm text-gray-500 uppercase tracking-wide sm:w-40 shrink-0">{label}</span>
              <span class="text-base text-gray-700">{items}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-14 border-t border-gray-100">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-sm font-medium text-gray-500 tracking-widest uppercase mb-6">
          <span class="text-cyan-700">[ 04 /</span> {t('home.community')} <span class="text-cyan-700">]</span>
        </h2>
        <div class="space-y-3">
          <div class="flex items-baseline gap-3">
            <a
              href="https://community.cncf.io/cloud-native-sevilla/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-base text-gray-700 hover:text-cyan-700 transition-colors"
            >
              Cloud Native Sevilla
            </a>
            <span class="text-sm text-gray-500">CNCF</span>
          </div>
          <div class="flex items-baseline gap-3">
            <a
              href="https://nan.builders/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-base text-gray-700 hover:text-cyan-700 transition-colors"
            >
              NaN
            </a>
            <span class="text-sm text-gray-500">AI builders</span>
          </div>
          <div class="flex items-baseline gap-3">
            <a
              href="https://remoandaluz.es/"
              target="_blank"
              rel="noopener noreferrer"
              title="Federación Andaluza de Remo"
              class="text-base text-gray-700 hover:text-cyan-700 transition-colors"
            >
              FAR
            </a>
            <span class="text-sm text-gray-500">Active rower</span>
          </div>
        </div>
      </div>
    </section>

    <section class="py-14 border-t border-gray-100">
      <div class="max-w-4xl mx-auto px-4">
        <a href={translatePath('/notes')} class="text-sm font-medium text-gray-500 tracking-widest uppercase mb-6 block group">
          <span class="text-cyan-700">[ 05 /</span> <span class="group-hover:text-cyan-700 transition-colors">{t('home.latest')}</span> <span class="text-cyan-700">]</span>
        </a>
        {notes.length > 0 && (
          <div class="divide-y divide-gray-100">
            {notes.map((note) => (
              <a href={translatePath(`/notes/${note.id}`)} class="group block py-3 first:pt-0">
                <span class="text-sm text-gray-500 block tabular-nums">{note.data.pubDate.toISOString().slice(0, 10)}</span>
                <span class="text-base text-gray-700 group-hover:text-cyan-700 transition-colors">{note.data.title}</span>
              </a>
            ))}
          </div>
        )}
        <a
          href={translatePath('/notes')}
          class="text-xs text-gray-500 hover:text-cyan-700 transition-colors mt-4 block"
        >
          <span aria-label="See all notes">more</span> &rarr;
        </a>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
