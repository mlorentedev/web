---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import { useTranslations, useTranslatedPath, getLocale } from '../i18n/utils';
import { projects } from '../data/portfolio';
import { getCollection, type CollectionEntry } from 'astro:content';

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const [page] = await getCollection('pages', ({ data }: CollectionEntry<'pages'>) => data.page === 'home' && data.lang === 'en');

const allProjects = projects;

const notes: CollectionEntry<'notes'>[] = (await getCollection('notes', ({ data }: CollectionEntry<'notes'>) => !data.draft && data.lang === 'en'))
  .sort((a: CollectionEntry<'notes'>, b: CollectionEntry<'notes'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const stack = [
  { label: 'On-Premises', items: 'Linux · Proxmox · Bare metal' },
  { label: 'Orchestration', items: 'Kubernetes · Docker · Helm' },
  { label: 'IaC', items: 'Terraform · Ansible' },
  { label: 'Languages', items: 'Python · Go' },
  { label: 'Observability', items: 'Prometheus · Grafana · Loki' },
  { label: 'CI/CD', items: 'GitHub Actions · ArgoCD' },
  { label: 'Cloud', items: 'AWS' },
];
---

<BaseLayout>
  <Header />
  <main id="main-content" class="flex-grow pt-16">
    <Hero />

    <section class="py-10">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-sm text-gray-500 tracking-wide uppercase mb-8">
          {t('home.projects')}
        </h2>
        <a href="https://github.com/mlorentedev" target="_blank" rel="noopener noreferrer">
          <img
            src="https://ghchart.rshah.org/0e7490/mlorentedev"
            alt={t('meta.ghchart.alt')}
            width="722"
            height="112"
            class="w-full mb-8 hover:opacity-80 transition-opacity"
            loading="lazy"
          />
        </a>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {allProjects.map((project) => (
            <div class="border border-gray-200 rounded-md p-4 hover:border-cyan-700 transition-colors flex flex-col">
              <h3 class="font-bold text-gray-800 text-sm leading-snug mb-2">
                {(project.url || project.github) ? (
                  <a
                    href={project.url || project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-cyan-700 transition-colors"
                  >
                    {project.title}
                  </a>
                ) : (
                  project.title
                )}
              </h3>
              <p class="text-gray-600 text-sm leading-relaxed mb-3 flex-grow">{project.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {project.tags.map((tag) => (
                  <a href={translatePath(`/tags/${tag.toLowerCase()}`)} class="px-1.5 py-0.5 text-xs rounded bg-gray-100 text-gray-500 hover:bg-cyan-700 hover:text-white transition-colors">
                    {tag}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-10">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-sm text-gray-500 tracking-wide uppercase mb-6">
          {t('home.stack')}
        </h2>
        <div class="space-y-2">
          {stack.map(({ label, items }) => (
            <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-3">
              <span class="text-xs text-gray-500 uppercase tracking-wide sm:w-32 shrink-0">{label}</span>
              <span class="text-sm text-gray-700">{items}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-10">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-sm text-gray-500 tracking-wide uppercase mb-6">
          {t('home.community')}
        </h2>
        <div class="space-y-3">
          <div class="flex items-baseline gap-3">
            <a
              href="https://community.cncf.io/cloud-native-sevilla/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-gray-700 hover:text-cyan-700 transition-colors"
            >
              Cloud Native Sevilla
            </a>
            <span class="text-xs text-gray-500">CNCF</span>
          </div>
          <p class="text-sm text-gray-500">
            Rower. Multi-year national champion, actively competing
          </p>
        </div>
      </div>
    </section>

    <section class="py-8">
      <div class="max-w-3xl mx-auto px-4">
        <a href={translatePath('/notes')} class="text-sm text-gray-500 tracking-wide uppercase mb-6 block hover:text-cyan-700 transition-colors">
          {t('home.latest')}
        </a>
        {notes.length > 0 && (
          <div class="divide-y divide-gray-100">
            {notes.map((note) => (
              <a href={translatePath(`/notes/${note.id}`)} class="group block py-3 first:pt-0">
                <span class="text-xs text-gray-500 block tabular-nums">{note.data.pubDate.toISOString().slice(0, 10)}</span>
                <span class="text-sm text-gray-700 group-hover:text-cyan-700 transition-colors">{note.data.title}</span>
              </a>
            ))}
          </div>
        )}
        <a
          href={translatePath('/notes')}
          class="text-xs text-gray-500 hover:text-cyan-700 transition-colors mt-4 block"
        >
          <span aria-label="See all notes">more</span> &rarr;
        </a>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
