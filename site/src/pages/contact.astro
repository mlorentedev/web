---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

const [page] = await getCollection('pages', ({ data }: CollectionEntry<'pages'>) => data.page === 'contact' && data.lang === 'en');
const { Content } = await render(page);
---

<BaseLayout
  title={page.data.title}
  description={page.data.description}
>
  <Header />
  <main id="main-content" class="flex-grow pt-20">
    <section class="py-12">
      <div class="max-w-3xl mx-auto px-4 prose prose-base max-w-none prose-p:text-base prose-p:text-gray-700 prose-headings:font-bold prose-headings:text-gray-800 prose-h1:text-3xl prose-h1:mb-10 prose-a:text-cyan-700 hover:prose-a:text-cyan-800">
        <Content />

        <div class="border-t border-gray-200 pt-8 not-prose">
          <a
            href="https://calendly.com/mlorentedev/consulting"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-6 py-2 bg-cyan-700 text-white rounded-md text-sm font-medium hover:bg-cyan-800 transition-colors focus:outline-none focus:ring-2 focus:ring-cyan-300"
          >
            Let's talk
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
