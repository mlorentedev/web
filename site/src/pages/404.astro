---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Not Found" description="This page doesn't exist.">
  <Header />
  <main id="main-content" class="flex-grow py-16">
    <section class="pt-20 pb-16 md:pt-24 md:pb-20">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h1 class="text-6xl font-extrabold text-gray-300 mb-6">404</h1>
        <p id="not-found-text" class="text-gray-500 text-lg mb-10">This page doesn't exist.</p>
        <a
          id="home-link"
          href="/"
          class="inline-block px-6 py-3 bg-cyan-700 hover:bg-cyan-800 text-white font-medium rounded-md transition-colors text-sm"
        >Go home</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  const isEs = window.location.pathname.startsWith('/es/') || window.location.pathname === '/es';

  if (isEs) {
    const text = document.getElementById('not-found-text');
    const link = document.getElementById('home-link');
    if (text) text.textContent = 'Esta página no existe.';
    if (link) {
      link.textContent = 'Ir al inicio';
      link.setAttribute('href', '/es/');
    }
    document.title = 'No encontrado | Manu Lorente';
  }
</script>
