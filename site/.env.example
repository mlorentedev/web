# Local development config for mlorente.dev (Astro reads .env from this dir).
# Copy to .env and adjust. Only PUBLIC_* vars are exposed to the client build.

# API base. Production/staging leave this UNSET: the site calls a relative `/api`
# and the edge (Traefik, in kubelab) routes it per environment (ADR-054), so the
# image bakes no host. The Astro dev server has no backend, so for local dev point
# this at a real API HOST — host only, no trailing /api; the call sites add the
# `/api/...` path themselves:
PUBLIC_API_URL=https://api.staging.kubelab.live
