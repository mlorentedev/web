# Local development config for mlorente.dev (Astro reads .env from this dir).
# Copy to .env and adjust. Only PUBLIC_* vars are exposed to the client build.

# API base URL the site calls. If unset, the app falls back to its built-in
# default (see src/data/site.ts). Per ADR-054 (kubelab#750) production will move
# to a same-origin relative /api; until then, set this explicitly for local dev.
PUBLIC_API_URL=https://api.staging.kubelab.live
